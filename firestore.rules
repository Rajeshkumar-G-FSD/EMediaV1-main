rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Quick Quote Tool submissions (src/components/BudgetEstimator.tsx).
    // Anyone can create a booking from the public site; only signed-in
    // admins (src/components/admin/AdminLogin.tsx) can read or update them.
    match /bookings/{bookingId} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }

    // Consultation form submissions (src/components/InquiryForm.tsx),
    // shown in the admin dashboard as "Quotes Enquiry". The client already
    // validates these fields, but Firestore rules re-check them here since
    // this project has no custom backend server to do it authoritatively.
    match /quoteEnquiries/{enquiryId} {
      allow create: if
        request.resource.data.fullName is string &&
        request.resource.data.fullName.size() >= 2 &&
        request.resource.data.fullName.size() <= 60 &&
        request.resource.data.phone is string &&
        request.resource.data.phone.matches('^[0-9]{10}$') &&
        request.resource.data.email is string &&
        request.resource.data.email.matches('^[^@\\s]+@[^@\\s]+[.][^@\\s]+$') &&
        request.resource.data.serviceType is string &&
        request.resource.data.serviceType.size() > 0 &&
        request.resource.data.notes is string &&
        request.resource.data.notes.size() <= 500 &&
        request.resource.data.category == 'Quotes Enquiry' &&
        request.resource.data.status == 'pending';
      allow read, update, delete: if request.auth != null;
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
